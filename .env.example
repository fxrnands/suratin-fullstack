# --- Supabase (browser / future @supabase/ssr client) ---
# Project Settings → API: Project URL + Publishable key (new dashboards) or anon JWT (legacy).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# --- Supabase Postgres (server only — required for Drizzle + auth + letters API) ---
# Use the connection string from: Settings → Database → Connection string.
#
# Prefer "Session pooler" (host like *.pooler.supabase.com). Direct `db.*.supabase.co:5432`
# often hits CONNECT_TIMEOUT from local networks (IPv6 / routing). Copy the exact URI from the dashboard.
# Always add ?sslmode=require if not already present.
#
# Examples (your region/host must match the dashboard):
# Session pooler (common): postgres://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
# Transaction pooler:      postgres://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
#
# After changing DATABASE_URL, restart `pnpm dev` (the DB client is cached).
#
# Schema: run drizzle/ SQL or `pnpm db:push` (0000_init_suratin.sql then 0001_marketing_sections.sql).
DATABASE_URL=""

# Same secret length constraints enforced at runtime for access tokens (HS256).
JWT_ACCESS_SECRET="change-me-at-least-16-chars-long"
# Examples: "15m", "1h", "900s"
JWT_ACCESS_EXPIRES="15m"

# Google Gemini (server only). @google/genai reads GEMINI_API_KEY from env with GoogleGenAI({}).
# Create a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Primary model, then optional comma-separated extras before built-in free-tier fallbacks (Flash family).
GEMINI_MODEL="gemini-3-flash-preview"
# Example: GEMINI_MODEL_FALLBACKS="gemini-2.5-flash,gemini-2.5-flash-lite"
GEMINI_MODEL_FALLBACKS=""
